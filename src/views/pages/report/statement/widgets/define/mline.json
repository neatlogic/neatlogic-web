{
  "name": "mline",
  "label": "多折线图",
  "type": "mline",
  "icon": "tsfont-chart-line",
  "widgetType": "basic",
  "hasCustomConfig": true,
  "width": 500,
  "height": 200,
  "padding": 5,
  "needData": true,
  "dataTypes": [{ "value": "dynamic", "text": "动态数据" }],
  "fields": [
    { "name": "xField", "label": "X轴字段", "type": "text", "isRequired": true },
    { "name": "yField", "label": "Y轴字段", "type": "number", "isRequired": true },
    { "name": "seriesField", "label": "分组字段", "type": "text", "isRequired": false }
  ],
  "config": {
    "legend": { "visible": true, "position": "bottom" },
    "smooth": false,
    "yAxis": { "title": { "text": "" } },
    "xAxis": {
      "label": {
        "autoHide": true,
        "autoEllipsis": true
      },
      "title": { "text": "" }
    }
  }
}
